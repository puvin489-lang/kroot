{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "kroot",
          "information_uri": "https://github.com/AnonJon/kroot",
          "rules": [
            {
              "id": "missing_secret_dependency_detected",
              "name": "Missing Secret dependency detected",
              "short_description": {
                "text": "Pod failing because secret db-password does not exist"
              }
            },
            {
              "id": "network_reachability_blocked_by_networkpolicy",
              "name": "Network reachability blocked by NetworkPolicy",
              "short_description": {
                "text": "Ingress/egress rules do not permit required peer and port communication"
              }
            },
            {
              "id": "service_selector_mismatch_detected",
              "name": "Service selector mismatch detected",
              "short_description": {
                "text": "Service selector does not match any pod labels"
              }
            }
          ]
        }
      },
      "results": [
        {
          "rule_id": "missing_secret_dependency_detected",
          "level": "error",
          "message": {
            "text": "Missing Secret dependency detected"
          },
          "locations": [
            {
              "logical_locations": [
                {
                  "name": "Pod/prod/payments-api"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 0.98,
            "root_cause": "Pod failing because secret db-password does not exist",
            "evidence": [
              "Pod/prod/payments-api -> Secret/db-password -> Secret missing source=pod.dependencies"
            ],
            "impact_score": 11.76,
            "impact_rank": 2,
            "remediation_summary": "Create the missing Secret or update pod references",
            "remediation_steps": [
              "Create the referenced secret in the same namespace as the failing pod",
              "Ensure expected key names match the pod env/volume references",
              "Restart workload rollout after the secret is created or corrected"
            ],
            "remediation_commands": [
              "kubectl create secret generic <secret-name> -n <namespace> --from-literal=<key>=<value>",
              "kubectl rollout restart deployment/<deployment> -n <namespace>"
            ]
          }
        },
        {
          "rule_id": "service_selector_mismatch_detected",
          "level": "warning",
          "message": {
            "text": "Service selector mismatch detected"
          },
          "locations": [
            {
              "logical_locations": [
                {
                  "name": "Service/prod/payments"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 0.9,
            "root_cause": "Service selector does not match any pod labels",
            "evidence": [
              "service=prod/payments selector=[app=payments] has no matched pods"
            ],
            "impact_score": 6.2999997,
            "impact_rank": 3,
            "remediation_summary": "Align Service selectors with workload pod labels",
            "remediation_steps": [
              "Compare service selector keys/values against pod labels",
              "Update the service selector or workload labels to match",
              "Confirm endpoints are populated after reconciliation"
            ],
            "remediation_commands": [
              "kubectl get svc <service> -n <namespace> -o yaml",
              "kubectl get pods -n <namespace> --show-labels",
              "kubectl get endpoints <service> -n <namespace>"
            ]
          }
        },
        {
          "rule_id": "network_reachability_blocked_by_networkpolicy",
          "level": "warning",
          "message": {
            "text": "Network reachability blocked by NetworkPolicy"
          },
          "locations": [
            {
              "logical_locations": [
                {
                  "name": "Pod/prod/payments-api"
                }
              ]
            }
          ],
          "properties": {
            "confidence": 0.84,
            "root_cause": "Ingress/egress rules do not permit required peer and port communication",
            "evidence": [
              "Pod/prod/payments-api -> NetworkPolicy/prod/deny-all (egress has no matching peers/ports in context policies=[NetworkPolicy/prod/deny-all]) source=networkpolicy.egress"
            ],
            "impact_score": 11.76,
            "impact_rank": 2,
            "remediation_summary": "Allow required peer and port combinations in NetworkPolicy",
            "remediation_steps": [
              "Identify blocked service or pod traffic paths from the evidence chain",
              "Add explicit ingress/egress peers and required ports for expected flows",
              "Re-test connectivity after applying policy updates"
            ],
            "remediation_commands": [
              "kubectl get networkpolicy -A",
              "kubectl describe networkpolicy <policy> -n <namespace>"
            ]
          }
        }
      ]
    }
  ]
}
